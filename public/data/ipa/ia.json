      "audioUrl": "",
      "type": "sentence",
      "partOfSpeech": "",
      "hidden": false
    },
    {
      "word": "Cheers to the New Year!",
      "ipa": "/tʃɪrz tə ðə nu jɪr/",
      "meaning": "Chúc mừng năm mới!",
      "audioUrl": "",
      "type": "sentence",
      "partOfSpeech": "",
      "hidden": false
    },
    {
      "word": "Would you like to go out for some beer?",
      "ipa": "/wʊd ju laɪk tə ɡoʊ aʊt fər səm bɪr/",
      "meaning": "Bạn có muốn đi uống bia không?",
      "audioUrl": "",
      "type": "sentence",
      "partOfSpeech": "",
      "hidden": false
    },
    {
      "word": "I can hear you clearly when you are near here.",
      "ipa": "/aɪ kæn hɪr ju ˈklɪrli wɛn ju ɑr nɪr hɪr/",
      "meaning": "Tôi có thể nghe bạn rõ khi bạn ở gần đây.",
      "audioUrl": "",
      "type": "sentence",
      "partOfSpeech": "",
      "hidden": false
    },
    {
      "word": "I hear a clear cheer near my dear friend every year.",
      "ipa": "/aɪ hɪr ə klɪr tʃɪr nɪr maɪ dɪr frend ˈɛvri jɪr/",
      "meaning": "Tôi nghe một tiếng cổ vũ rõ ràng gần người bạn thân mỗi năm.",
      "audioUrl": "",
      "type": "sentence",
      "partOfSpeech": "",
      "hidden": false
    },
    {
      "word": "Dear peers near here, hear clear cheers every year!",
      "ipa": "/dɪr pɪrz nɪr hɪr hɪr klɪr tʃɪrz ˈɛvri jɪr/",
      "meaning": "Các bạn thân mến gần đây, hãy nghe tiếng cổ vũ rõ ràng mỗi năm!",
      "audioUrl": "",
      "type": "sentence",
      "partOfSpeech": "",
      "hidden": false
    },
    {
      "word": "I fear I cannot hear clearly near here this year.",
      "ipa": "/aɪ fɪr aɪ ˈkænɑt hɪr ˈklɪrli nɪr hɪr ðɪs jɪr/",
      "meaning": "Tôi sợ rằng tôi không thể nghe rõ gần đây năm nay.",
