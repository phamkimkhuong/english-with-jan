          "hidden": false
        },
        {
          "word": "go to the theatre",
          "ipa": "/ɡoʊ tə ðə ˈθiːətər / ˈmuvi/",
          "meaning": "đi nhà hát / đi xem phim",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "It’s nearly 5pm",
          "ipa": "/ɪts ˈnɪrli faɪv piː em/",
          "meaning": "sắp 5 giờ chiều",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Can you hear me clearly?",
          "ipa": "/kæn ju hɪr mi ˈklɪrli/",
          "meaning": "Bạn có nghe rõ tôi không?",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": ".I travel every year.",
          "ipa": "/aɪ ˈtrævəl ˈɛvri jɪr/",
          "meaning": "Tôi đi du lịch mỗi năm.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "He sheds a tear because of fear.",
          "ipa": "/hi ʃɛdz ə tɪr bɪˈkɔz əv fɪr/",
          "meaning": "Anh ấy rơi nước mắt vì sợ hãi.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Cheers to the New Year!",
          "ipa": "/tʃɪrz tə ðə nu jɪr/",
          "meaning": "Chúc mừng năm mới!",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Would you like to go out for some beer?",
          "ipa": "/wʊd ju laɪk tə ɡoʊ aʊt fər səm bɪr/",
          "meaning": "Bạn có muốn đi uống bia không?",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I can hear you clearly when you are near here.",
          "ipa": "/aɪ kæn hɪr ju ˈklɪrli wɛn ju ɑr nɪr hɪr/",
          "meaning": "Tôi có thể nghe bạn rõ khi bạn ở gần đây.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I hear a clear cheer near my dear friend every year.",
          "ipa": "/aɪ hɪr ə klɪr tʃɪr nɪr maɪ dɪr frend ˈɛvri jɪr/",
          "meaning": "Tôi nghe một tiếng cổ vũ rõ ràng gần người bạn thân mỗi năm.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Dear peers near here, hear clear cheers every year!",
