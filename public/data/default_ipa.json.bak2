        },
        {
          "word": "stay safe home",
          "ipa": "/steɪ seɪf hoʊm/",
          "meaning": "ở nhà an toàn",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "make a change",
          "ipa": "/meɪk ə tʃeɪndʒ/",
          "meaning": "tạo thay đổi",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "They make a cake for the party.",
          "ipa": "/ðeɪ meɪk ə keɪk fər ðə ˈpɑːrti/",
          "meaning": "Họ làm một cái bánh cho bữa tiệc.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "3She stays in a safe place every day.",
          "ipa": "/ʃi steɪz ɪn ə seɪf pleɪs ˈevri deɪ/",
          "meaning": "Cô ấy ở một nơi an toàn mỗi ngày.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "The rain makes the train late.",
          "ipa": "/ðə reɪn meɪks ðə treɪn leɪt/",
          "meaning": "Cơn mưa làm tàu bị trễ.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "She will stay at home today.",
          "ipa": "/ʃi wɪl steɪ æt hoʊm təˈdeɪ/",
          "meaning": "Cô ấy sẽ ở nhà hôm nay.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Don’t just complain, explain the situation and find a good solution.",
          "ipa": "/doʊnt dʒʌst kəmˈpleɪn ɪkˈspleɪn ðə ˌsɪtʃuˈeɪʃən ənd faɪnd ə ɡʊd səˈluːʃən/",
          "meaning": "Đừng chỉ phàn nàn, hãy giải thích tình huống và tìm một giải pháp tốt.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "My eighty-eight father still likes playing baseball.",
          "ipa": "/maɪ ˈeɪti eɪt ˈfɑːðər stɪl laɪks ˈpleɪɪŋ ˈbeɪsˌbɔːl/",
          "meaning": "Bố 88 tuổi của tôi vẫn thích chơi bóng chày.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "It’s Monday and I want to be lazy.",
          "ipa": "/ɪts ˈmʌndeɪ ənd aɪ wɑːnt tə bi ˈleɪzi/",
          "meaning": "Hôm nay là thứ Hai và tôi muốn lười biếng.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "A brave baker bakes a great cake in May.",
          "ipa": "/ə breɪv ˈbeɪkər beɪks ə ɡreɪt keɪk ɪn meɪ/",
          "meaning": "Một thợ làm bánh dũng cảm làm bánh ngon vào tháng 5.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "They say the same name on a rainy day.",
          "ipa": "/ðeɪ seɪ ðə seɪm neɪm ɑːn ə ˈreɪni deɪ/",
          "meaning": "Họ nói cùng một cái tên vào một ngày mưa.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
