        {
          "word": "open door",
          "ipa": "/ˈoʊpən dɔːr/",
          "meaning": "cửa mở",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I close the door.",
          "ipa": "/aɪ kloʊz ðə dɔːr/",
          "meaning": "Tôi đóng cửa.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I hope to go home before the show is over.",
          "ipa": "/aɪ hoʊp tə ɡoʊ hoʊm bɪˈfɔːr ðə ʃoʊ ɪz ˈoʊvər/",
          "meaning": "Tôi hy vọng về nhà trước khi buổi diễn kết thúc.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "They close the road near the old stone home.",
          "ipa": "/ðeɪ kloʊz ðə roʊd nɪr ði oʊld stoʊn hoʊm/",
          "meaning": "Họ đóng con đường gần ngôi nhà đá cũ.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "We hope it’s going to snow tomorrow.",
          "ipa": "/wi hoʊp ɪts ˈɡoʊɪŋ tə snoʊ təˈmɑːroʊ/",
          "meaning": "Chúng tôi hy vọng ngày mai trời sẽ có tuyết.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Oh no! Don’t open the window. It’s cold!",
          "ipa": "/oʊ noʊ! doʊnt ˈoʊpən ðə ˈwɪndoʊ. ɪts koʊld!/",
          "meaning": "Ôi không! Đừng mở cửa sổ. Trời lạnh đấy!",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I’m sorry. I don’t know you’re joking.",
          "ipa": "/aɪm ˈsɑːri. aɪ doʊnt noʊ jʊr ˈdʒoʊkɪŋ/",
          "meaning": "Tôi xin lỗi. Tôi không biết bạn đang đùa.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Go slow so the snow won’t blow over the old stone home.",
          "ipa": "/ɡoʊ sloʊ soʊ ðə snoʊ woʊnt bloʊ ˈoʊvər ði oʊld stoʊn hoʊm/",
          "meaning": "Đi chậm để tuyết không thổi qua ngôi nhà đá cũ.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Joe goes home and shows cold snow on the road.",
          "ipa": "/dʒoʊ ɡoʊz hoʊm ænd ʃoʊz koʊld snoʊ ɑːn ðə roʊd/",
          "meaning": "Joe về nhà và cho thấy tuyết lạnh trên đường.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "No one knows how low the snow goes on the old road home.",
          "ipa": "/noʊ wʌn noʊz haʊ loʊ ðə snoʊ ɡoʊz ɑːn ði oʊld roʊd hoʊm/",
          "meaning": "Không ai biết tuyết thấp đến đâu trên con đường cũ về nhà.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I close the door.",
          "ipa": "/aɪ kloʊz ðə dɔːr/",
          "meaning": "Tôi đóng cửa.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
