        },
        {
          "word": "boil the toy",
          "ipa": "/bɔɪl ðə tɔɪ/",
          "meaning": "đun đồ chơi (ngữ cảnh luyện âm)",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "enjoy the voice",
          "ipa": "/ɪnˈdʒɔɪ ðə vɔɪs/",
          "meaning": "tận hưởng giọng nói",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "The boy has a toy.",
          "ipa": "/ðə bɔɪ hæz ə tɔɪ/",
          "meaning": "Cậu bé có một món đồ chơi.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I enjoy the noise.",
          "ipa": "/aɪ ɪnˈdʒɔɪ ðə nɔɪz/",
          "meaning": "Tôi thích tiếng ồn.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Please avoid the poison.",
          "ipa": "/pliːz əˈvɔɪd ðə ˈpɔɪzən/",
          "meaning": "Hãy tránh chất độc.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "The noisy boy enjoys a toy.",
          "ipa": "/ðə ˈnɔɪzi bɔɪ ɪnˈdʒɔɪz ə tɔɪ/",
          "meaning": "Cậu bé ồn ào thích một món đồ chơi.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Do not avoid it. It’s your choice.",
          "ipa": "/duː nɒt əˈvɔɪd ɪt. ɪts jʊər tʃɔɪs/",
          "meaning": "Đừng tránh nó. Đó là lựa chọn của bạn.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I can’t enjoy this movie because of the annoying noise from that boy.",
          "ipa": "/aɪ kænt ɪnˈdʒɔɪ ðɪs ˈmuːvi bɪˈkɔːz əv ði əˈnɔɪɪŋ nɔɪz frəm ðæt bɔɪ/",
          "meaning": "Tôi không thể tận hưởng bộ phim này vì tiếng ồn khó chịu từ cậu bé đó.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Don’t destroy yourself by being disappointed so much.",
          "ipa": "/doʊnt dɪˈstrɔɪ jɔːrˈsɛlf baɪ ˈbiːɪŋ ˌdɪsəˈpɔɪntɪd soʊ mʌtʃ/",
          "meaning": "Đừng tự hủy hoại bản thân vì thất vọng quá nhiều.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I have an appointment with an employee who works in a very enjoyable company.",
          "ipa": "/aɪ hæv ən əˈpɔɪntmənt wɪð ən ɪmˈplɔɪiː huː wɜːrks ɪn ə ˈenʤɔɪəbəl ˈkʌmpəni/",
          "meaning": "Tôi có một cuộc hẹn với một nhân viên làm việc trong một công ty rất thú vị.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Don’t disappoint your team when you join the meeting, because every point is important.",
          "ipa": "/doʊnt ˌdɪsəˈpɔɪnt jɔːr tiːm wen ju dʒɔɪn ðə ˈmiːtɪŋ bɪˈkɒz ˈevri pɔɪnt ɪz ɪmˈpɔːrtənt/",
          "meaning": "Đừng làm đội của bạn thất vọng khi tham gia cuộc họp, vì mọi điểm đều quan trọng.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
