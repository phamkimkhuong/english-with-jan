          "meaning": "giá hợp lý",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "in the air",
          "ipa": "/ɪn ði er/",
          "meaning": "trong không khí",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "over there",
          "ipa": "/ˈoʊvər ðer/",
          "meaning": "ở đằng kia",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "their house",
          "ipa": "/ðer haʊs/",
          "meaning": "nhà của họ",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "anywhere else",
          "ipa": "/ˈeniwer els/",
          "meaning": "nơi nào khác",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": ".I don’t care.",
          "ipa": "/aɪ doʊnt ker/",
          "meaning": "Tôi không quan tâm.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "The air is fresh.",
          "ipa": "/ðə er ɪz freʃ/",
          "meaning": "Không khí rất trong lành.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "She has fair hair.",
          "ipa": "/ʃi hæz fer her/",
          "meaning": "Cô ấy có mái tóc vàng nhạt.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I prepare for the exam with care.",
          "ipa": "/aɪ prɪˈper fər ði ɪɡˈzæm wɪð ker/",
          "meaning": "Tôi chuẩn bị cho kỳ thi một cách cẩn thận.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "They compare their answers over there.",
          "ipa": "/ðeɪ kəmˈper ðer ˈænsərz ˈoʊvər ðer/",
          "meaning": "Họ so sánh câu trả lời của họ ở đằng kia.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "We repair the car in the fresh air.",
          "ipa": "/wi rɪˈper ðə kɑːr ɪn ðə freʃ er/",
          "meaning": "Chúng tôi sửa xe trong không khí trong lành.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Rare pairs of fair-haired bears share care in the air.",
