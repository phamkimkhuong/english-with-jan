        },
        {
          "word": "a round cloud",
          "ipa": "/ə raʊnd klaʊd/",
          "meaning": "đám mây tròn",
          "audioUrl": "",
          "type": "phrase",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "There are flowers all around the house.",
          "ipa": "/ðer ɑːr ˈflaʊ.ərz ɔːl əˈraʊnd ðə haʊs/",
          "meaning": "Có những bông hoa khắp xung quanh ngôi nhà.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Let’s countdown: 3, 2, 1, Happy New Year.",
          "ipa": "/lets ˈkaʊnt.daʊn θriː tuː wʌn ˈhæpi nuː jɪr/",
          "meaning": "Hãy đếm ngược: 3, 2, 1, Chúc mừng năm mới.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I go around the mountain for about an hour.",
          "ipa": "/aɪ ɡoʊ əˈraʊnd ðə ˈmaʊn.tən fər əˈbaʊt ən ˈaʊər/",
          "meaning": "Tôi đi quanh ngọn núi khoảng một giờ.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Playing outside is better.",
          "ipa": "/ˈpleɪɪŋ ˌaʊtˈsaɪd ɪz ˈbetər/",
          "meaning": "Chơi ở bên ngoài thì tốt hơn.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "The loud sound comes from downtown.",
          "ipa": "/ðə laʊd saʊnd kʌmz frəm ˌdaʊnˈtaʊn/",
          "meaning": "Âm thanh lớn phát ra từ khu trung tâm thành phố.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "I found my mouse outside the house.",
          "ipa": "/aɪ faʊnd maɪ maʊs ˌaʊtˈsaɪd ðə haʊs/",
          "meaning": "Tôi tìm thấy con chuột của mình ở bên ngoài ngôi nhà.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "A loud crowd shouted around the town.",
          "ipa": "/ə laʊd kraʊd ˈʃaʊtɪd əˈraʊnd ðə taʊn/",
          "meaning": "Một đám đông ồn ào hét lên quanh thị trấn.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
          "word": "Brown clouds around the mountain sound loud.",
          "ipa": "/braʊn klaʊdz əˈraʊnd ðə ˈmaʊntɪn saʊnd laʊd/",
          "meaning": "Những đám mây nâu quanh núi nghe rất ồn ào.",
          "audioUrl": "",
          "type": "sentence",
          "partOfSpeech": "",
          "hidden": false
        },
        {
