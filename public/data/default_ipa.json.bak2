          "audioUrl": "",
          "type": "phrase",
          "hidden": false
        },
        {
          "word": "a short story",
          "ipa": "/ə ʃɔːrt ˈstɔːri/",
          "meaning": "truyện ngắn",
          "audioUrl": "",
          "type": "phrase",
          "hidden": false
        },
        {
          "word": "north of Vietnam",
          "ipa": "/nɔːrθ əv ˌviːetˈnɑːm/",
          "meaning": "miền Bắc Việt Nam",
          "audioUrl": "",
          "type": "phrase",
          "hidden": false
        },
        {
          "word": "Can you open the door, please?",
          "ipa": "/kæn juː ˈoʊpən ðə dɔːr pliːz/",
          "meaning": "Bạn có thể mở cửa giúp tôi được không?",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "Do you like it? Of course!",
          "ipa": "/duː juː laɪk ɪt? əv kɔːrs/",
          "meaning": "Bạn thích nó chứ? Tất nhiên rồi!",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "More forks are on the floor.",
          "ipa": "/mɔːr fɔːrks ɑːr ɑːn ðə flɔːr/",
          "meaning": "Nhiều cái nĩa ở trên sàn.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "The horse is near the store door.",
          "ipa": "/ðə hɔːrs ɪz nɪr ðə stɔːr dɔːr/",
          "meaning": "Con ngựa ở gần cửa hàng.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "I was born and raised in the north of Vietnam.",
          "ipa": "/aɪ wəz bɔːrn ənd reɪzd ɪn ðə nɔːrθ əv ˌviːetˈnɑːm/",
          "meaning": "Tôi sinh ra và lớn lên ở miền Bắc Việt Nam.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "More and more horses ran across the floor.",
          "ipa": "/mɔːr ænd mɔːr ˈhɔːrsɪz ræn əˈkrɔːs ðə flɔːr/",
          "meaning": "Ngày càng nhiều con ngựa chạy qua sàn.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "The short horse wore more orange shorts.",
          "ipa": "/ðə ʃɔːrt hɔːrs wɔːr mɔːr ˈɔːrɪndʒ ʃɔːrts/",
          "meaning": "Con ngựa thấp mặc thêm quần short màu cam.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "Of course, learning a foreign language requires time and effort.",
          "ipa": "/əv kɔːrs ˈlɜːrnɪŋ ə ˈfɔːrən ˈlæŋɡwɪdʒ rɪˈkwaɪərz taɪm ənd ˈefərt/",
          "meaning": "Tất nhiên, học một ngoại ngữ đòi hỏi thời gian và nỗ lực.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "Four short horses snored on the floor near the store door.",
          "ipa": "/fɔːr ʃɔːrt ˈhɔːrsɪz snɔːrd ɑːn ðə flɔːr nɪr ðə stɔːr dɔːr/",
          "meaning": "Bốn con ngựa thấp ngáy trên sàn gần cửa hàng.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
        },
        {
          "word": "Although the course was difficult, it was worth every hour of hard work.",
          "ipa": "/ɔːlˈðoʊ ðə kɔːrs wəz ˈdɪfɪkəlt ɪt wəz wɜːrθ ˈevri ˈaʊər əv hɑːrd wɜːrk/",
          "meaning": "Mặc dù khóa học khó, nhưng nó xứng đáng với từng giờ làm việc chăm chỉ.",
          "audioUrl": "",
          "type": "sentence",
          "hidden": false
