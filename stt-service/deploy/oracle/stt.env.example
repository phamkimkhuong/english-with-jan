STT_MODEL_PATH=/opt/english-with-jan-stt/models/vosk-model-small-en-us-0.15
STT_ALLOWED_ORIGINS=https://YOUR_APP_DOMAIN_HERE
STT_MAX_AUDIO_BYTES=5242880
STT_MAX_AUDIO_SECONDS=8
STT_FFMPEG_TIMEOUT_SECONDS=15
STT_FFMPEG_PATH=/usr/bin/ffmpeg
STT_AUTH_REQUIRED=true
STT_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
STT_RATE_LIMIT_PER_MINUTE=30